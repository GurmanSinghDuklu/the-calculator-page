{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/((?!$).*)/",
      "destination": "/$1",
      "permanent": true
    },
    {
      "source": "/finance/mortgage-calculator",
      "destination": "/finance/mortgage",
      "permanent": true
    },
    {
      "source": "/finance/loan-calculator",
      "destination": "/finance/loan",
      "permanent": true
    },
    {
      "source": "/finance/retirement-calculator",
      "destination": "/finance/retirement",
      "permanent": true
    },
    {
      "source": "/categories/health",
      "destination": "/misc/bmi-calculator",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(sitemap.xml|robots.txt|manifest.json)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
