# Anthropic API Key (get from https://console.anthropic.com/api/keys)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Bing Webmaster API Key (get from Bing Webmaster Tools → Settings → API Access)
# Leave blank if not using Bing pinging
BING_WEBMASTER_API_KEY=

# Google Indexing API service account (same as main project)
# Path to service-account.json (relative to this directory)
GOOGLE_SERVICE_ACCOUNT_PATH=../service-account.json

# Site configuration
SITE_URL=https://www.thecalculatorpage.com
SITE_ROOT_PATH=../../

# Logging
LOG_LEVEL=info

# Daily run time (24-hour format, e.g., "03:00" for 3 AM)
DAILY_RUN_TIME=03:00

# Debug mode (set to true to see verbose output)
DEBUG=false
